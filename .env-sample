# LLM (pydantic-ai auto-discovers the provider from the model name
# and reads the API key from the standard provider env var, e.g. ANTHROPIC_API_KEY or OPENAI_API_KEY)
#ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
#PYDANTIC_AI_MODEL=anthropic:claude-sonnet-4-6
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
PYDANTIC_AI_MODEL=openai:gpt-5.4-nano

# Image generation via pydantic-ai (requires OPENAI_API_KEY for openai-responses models)
# OPENAI_API_KEY is already set above (shared for both LLM and image generation)
PYDANTIC_AI_IMAGE_MODEL=openai-responses:gpt-image-1-mini

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_TASK_QUEUE=bedtime-story

# Web UI
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8000
