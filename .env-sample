# LLM (pydantic-ai auto-discovers the provider from the model name
# and reads the API key from the standard provider env var, e.g. ANTHROPIC_API_KEY or OPENAI_API_KEY)
#ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
#PYDANTIC_AI_MODEL=anthropic:claude-sonnet-4-6
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
PYDANTIC_AI_MODEL=openai:gpt-5.4-mini

# Image generation via OpenAI Images API (requires OPENAI_API_KEY, shared with LLM above).
# gpt-image-2 (ChatGPT Images 2.0) requires a verified OpenAI organization:
# https://platform.openai.com/settings/organization/general
# If your org is not verified, use gpt-image-1.5 instead (no verification required).
OPENAI_IMAGE_MODEL=gpt-image-2

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_TASK_QUEUE=bedtime-story

# Web UI
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8000
