# syntax=docker/dockerfile:1
FROM python:3.13-slim AS build
WORKDIR /app
ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-install-project
COPY worker/ worker/
# --no-editable: install the project as a regular (non-editable) package. A
# built image never needs an editable install, and it avoids uv writing an
# editable wheel into the cache mount — a write that fails with EPERM under
# rootless Podman's user-namespace uid mapping.
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-editable

FROM python:3.13-slim AS runtime
WORKDIR /app
ENV PATH="/app/.venv/bin:$PATH"
RUN useradd --create-home --uid 1000 app
COPY --from=build --chown=app:app /app /app
# Pre-create the illustrations directory owned by app. The "illustrations"
# named volume is mounted here; Docker initializes a fresh volume's ownership
# from this path, so the non-root app user can write generated images.
RUN install -d -o app -g app /app/static /app/static/illustrations
USER app
CMD ["python", "-m", "worker"]
